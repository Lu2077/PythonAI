      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.interpolate import interp1d\n",
        "\n",
        "tiempo = [1,2,3,4]\n",
        "temperatura = []\n",
        "\n",
        "i1 = float(input(\"ingrese temperatura: \"))\n",
        "temperatura.append(i1)\n",
        "\n",
        "i2 = float(input(\"ingrese temperatura: \"))\n",
        "temperatura.append(i2)\n",
        "\n",
        "i3 = float(input(\"ingrese temperatura: \"))\n",
        "temperatura.append(i3)\n",
        "\n",
        "i4 = float(input(\"ingrese temperatura: \"))\n",
        "temperatura.append(i4)\n",
        "\n",
        "plt.plot(tiempo, temperatura, 'ro', label = 'datos')\n",
        "\n",
        "f = interp1d(tiempo, temperatura, kind='cubic')\n",
        "tiempo_nuevo = np.linspace(1,4,100)\n",
        "temperatura_suave = f(tiempo_nuevo)\n",
        "\n",
        "plt.plot(tiempo_nuevo, temperatura_suave, 'g', label = 'interpolacion')\n",
        "plt.title('tiempo vs temperatura')\n",
        "plt.xlabel('time')\n",
        "plt.ylabel('celcius')\n",
        "plt.legend(loc = 'best')\n",
        "plt.grid(True)\n",
        "plt.show()"
      ]
    }
  ]
}